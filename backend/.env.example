# --- AI (optional) ---------------------------------------------------
# Get a free key at https://console.groq.com . Leave blank to run the
# deterministic rule-based extractor at Rs. 0 (no key, no internet needed).
GROQ_API_KEY= 
GROQ_MODEL=llama-3.3-70b-versatile

# --- Database --------------------------------------------------------
# Local default is SQLite (no setup). For production use PostgreSQL, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/adhikar
DATABASE_URL=sqlite:///./adhikar.db

# --- Frontend origin (CORS) -----------------------------------------
CLIENT_URL=http://localhost:3000
