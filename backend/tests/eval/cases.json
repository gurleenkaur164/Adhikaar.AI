  {
    "id": "disability-unspecified",
    "text": "Mohan Lal is a 42 year old disabled man from a village in Rajasthan. He has a BPL ration card.",
    "language": "en",
    "note": "No disability PERCENTAGE is stated. IGNDPS requires 80%. Assuming 40% makes the scheme FAIL and drop off the operator's screen entirely; leaving it null keeps it visible as 'likely' for the operator to confirm. Unknown must stay unknown.",
    "expected": {
      "name": "Mohan Lal",
      "age": 42,
      "gender": "male",
      "area": "rural",
      "state": "Rajasthan",
      "is_bpl": true
    },
    "expect_null": [
      "disability_percent"
    ],
    "expected_statuses": {
      "igndps": "likely"
    }
  },
  {
    "id": "disability-below-threshold",
    "text": "Prakash, 45, has 60% disability, lives in an urban area of Maharashtra and is BPL.",
    "language": "en",
    "note": "60% is below the IGNDPS 80% threshold, so not_eligible is the CORRECT answer. Locks in that a genuine, stated shortfall is honoured.",
    "expected": {
      "age": 45,
      "disability_percent": 60,
      "area": "urban",
      "state": "Maharashtra",
      "is_bpl": true,
      "name": "Prakash"
    },
    "expected_statuses": {
      "igndps": "not_eligible"
    }
  },
